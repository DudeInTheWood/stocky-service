{
  "name": "stock-watcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal stock and ETF monitoring service.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "dev:ai": "tsx watch src/ai-main.ts",
    "dev:ai:run": "tsx src/ai-main.ts --run-once",
    "dev:context:run": "tsx src/ai-main.ts --refresh-context-once",
    "dev:morning:run": "tsx src/ai-main.ts --run-morning-once",
    "local:start": "bash scripts/start-local.sh",
    "local:stop": "bash scripts/stop-local.sh",
    "start": "node dist/main.js",
    "start:ai": "node dist/ai-main.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
